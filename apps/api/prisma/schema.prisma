generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  phone        String?   @unique
  passwordHash String
  role         Role?
  isActive     Boolean   @default(true)
  lastActiveAt DateTime?

  profile        Profile?
  photos         Photo[]
  posts          Post[]
  postSwipes     PostSwipe[]
  latestUserPost LatestUserPost? @relation("LatestUserPostUser")
  likesSent      Like[]          @relation("LikesSent")
  likesReceived  Like[]          @relation("LikesReceived")
  matchesA       Match[]         @relation("MatchA")
  matchesB       Match[]         @relation("MatchB")
  messages       Message[]
  userSubscriptions UserSubscription[]
  blocksSent     Block[]         @relation("BlocksSent")
  blocksReceived Block[]         @relation("BlocksReceived")
  swipesSent     Swipe[]         @relation("SwipesSent")
  swipesReceived Swipe[]         @relation("SwipesReceived")
  reportsGiven    Report[] @relation("Reporter")
  reportsReceived Report[] @relation("ReportedUser")

  devices       UserDevice[]
  refreshTokens RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Profile {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id])

  name       String?
  userName   String?    @unique
  gender     Gender
  bio        String?
  birthDate  DateTime   @db.Date
  heightCm   Int?
  lookingFor LookingFor

  interests String[] @default([])

  latitude  Float
  longitude Float
  city      String?
  country   String?

  matchPreference ProfileMatchPreference?

  isHidden     Boolean @default(false)
  isRegistered Boolean @default(false)
  isVerified   Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([latitude, longitude])
  @@map("profiles")
}

model ProfileMatchPreference {
  id        String  @id @default(uuid()) @db.Uuid
  profileId String  @unique @db.Uuid
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  minAge Int @default(18)
  maxAge Int @default(99)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([minAge, maxAge])
  @@map("profile_match_preferences")
}

model UserDevice {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id])

  fcmToken String
  platform String
  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  @@unique([fcmToken])
  @@index([userId])
  @@map("user_devices")
}

model RefreshToken {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id])

  tokenHash String
  isRevoked Boolean  @default(false)
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Photo {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id])

  url       String
  fileId    String
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("photos")
}

model Post {
  id            String          @id @default(uuid()) @db.Uuid
  userId        String          @db.Uuid
  user          User            @relation(fields: [userId], references: [id])
  swipes        PostSwipe[]
  latestForUser LatestUserPost? @relation("LatestUserPostPost")

  prompt       String?
  imageUrls    String[]
  imageFileIds String[]

  latitude  Float
  longitude Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@map("posts")
}

model LatestUserPost {
  userId String @id @db.Uuid
  postId String @unique @db.Uuid

  postCreatedAt DateTime
  latitude      Float
  longitude     Float

  user User @relation("LatestUserPostUser", fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation("LatestUserPostPost", fields: [postId], references: [id], onDelete: Cascade)

  @@index([postCreatedAt(sort: Desc)])
  @@index([latitude, longitude])
  @@index([latitude, longitude, postCreatedAt(sort: Desc)])
  @@map("latest_user_posts")
}

model PostSwipe {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  postId String @db.Uuid

  type SwipeType

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([postId])
  @@index([userId])
  @@map("post_swipes")
}

model Like {
  id         String @id @default(uuid()) @db.Uuid
  fromUserId String @db.Uuid
  toUserId   String @db.Uuid

  fromUser User @relation("LikesSent", fields: [fromUserId], references: [id])
  toUser   User @relation("LikesReceived", fields: [toUserId], references: [id])

  createdAt DateTime @default(now())

  @@unique([fromUserId, toUserId])
  @@map("likes")
}

model Match {
  id      String @id @default(uuid()) @db.Uuid
  userAId String @db.Uuid
  userBId String @db.Uuid

  userA User @relation("MatchA", fields: [userAId], references: [id])
  userB User @relation("MatchB", fields: [userBId], references: [id])

  chat Chat?

  createdAt DateTime @default(now())

  @@unique([userAId, userBId])
  @@map("matches")
}

model Chat {
  id      String @id @default(uuid()) @db.Uuid
  matchId String @unique @db.Uuid
  match   Match  @relation(fields: [matchId], references: [id])

  messages Message[]

  createdAt DateTime @default(now())

  @@map("chats")
}

model Message {
  id       String @id @default(uuid()) @db.Uuid
  chatId   String @db.Uuid
  senderId String @db.Uuid

  chat   Chat @relation(fields: [chatId], references: [id])
  sender User @relation(fields: [senderId], references: [id])

  content String
  isRead  Boolean @default(false)

  createdAt DateTime @default(now())

  @@map("messages")
}

model Block {
  id        String @id @default(uuid()) @db.Uuid
  blockerId String @db.Uuid
  blockedId String @db.Uuid

  blocker User @relation("BlocksSent", fields: [blockerId], references: [id])
  blocked User @relation("BlocksReceived", fields: [blockedId], references: [id])

  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@map("blocks")
}

model SubscriptionPlan {
  id          String @id @default(uuid()) @db.Uuid
  // `code` is the tier (FREE / PLUS / GOLD). Multiple SKUs per tier are allowed
  // (e.g. 7-day Gold + 30-day Gold). FREE is constrained to a single row via a
  // partial unique index in the migration (Prisma cannot express partial
  // uniques in schema syntax, so it lives in migration SQL).
  code        Plan
  name        String
  description String?

  durationDays Int  @default(30)
  isActive     Boolean @default(true)
  sortOrder    Int  @default(0)

  canReverseLastSwipe Boolean @default(false)
  canChangeSwipeDecision Boolean @default(false)
  canSeeWhoLikedYou Boolean @default(false)
  showLikesInAdvancedHome Boolean @default(false)

  dailySwipeLimit Int @default(20)
  dailySuperLikes Int @default(0)
  monthlyBoosts   Int @default(0)
  canUnblurLikes  Boolean @default(false)
  canPassport     Boolean @default(false)
  hideAds         Boolean @default(false)

  // Price is stored as Decimal so currency arithmetic stays exact.
  // Currency itself is global (see AppSettings.currency) — not per-plan —
  // because the catalog is sold in a single store currency.
  price           Decimal @default(0) @db.Decimal(10, 2)

  userSubscriptions UserSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@map("subscription_plans")
}

model UserSubscription {
  id                 String @id @default(uuid()) @db.Uuid
  userId             String @db.Uuid
  subscriptionPlanId String @db.Uuid

  plan     Plan
  startAt  DateTime
  endAt    DateTime
  isActive Boolean  @default(true)
  cancelledAt DateTime?

  user             User             @relation(fields: [userId], references: [id])
  subscriptionPlan SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive, endAt])
  @@index([subscriptionPlanId])
  @@map("user_subscriptions")
}

model Swipe {
  id         String @id @default(uuid()) @db.Uuid
  fromUserId String @db.Uuid
  toUserId   String @db.Uuid

  type SwipeType

  fromUser User @relation("SwipesSent", fields: [fromUserId], references: [id])
  toUser   User @relation("SwipesReceived", fields: [toUserId], references: [id])

  createdAt DateTime @default(now())

  @@unique([fromUserId, toUserId])
  @@map("swipes")
}

model Report {
  id       String @id @default(uuid()) @db.Uuid
  isSolved Boolean  @default(false)
  description String?
  userId          String   @db.Uuid
  reportedUserId  String   @db.Uuid
  reporter        User     @relation("Reporter", fields: [userId], references: [id])
  reportedUser    User     @relation("ReportedUser", fields: [reportedUserId], references: [id])

  createdAt DateTime @default(now())

  @@map("reports")
}

// Singleton global app settings (a single row, id pinned). The migration
// seeds one row at install time; admin endpoints only ever UPDATE it.
model AppSettings {
  id        String   @id @default("singleton")
  appName   String   @default("Dating Admin")
  currency  String   @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

enum SwipeType {
  LIKE
  PASS
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum LookingFor {
  LONG_TERM_RELATIONSHIP
  SERIOUS_DATING
  MARRIAGE_MINDED
  CASUAL_DATING
  NEW_FRIENDS
  OPEN_TO_ANYTHING
}

enum Plan {
  FREE
  PLUS
  GOLD
}

enum Role {
  admin
  user
}
